# ===== OpenAI / LLM Configuration =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
MAX_EXTRACTION_TOKENS=15000
LLM_TEMPERATURE=0.2

# ===== Scraper Configuration =====
MAX_TIMEOUT=60000
BLOCK_RESOURCES=true
BLOCK_ADS=true
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
# Maximum response body accepted from a fetched page (bytes). Default 10MB.
MAX_RESPONSE_BYTES=10485760

# ===== Security =====
# REQUIRED in production. Comma-separated list allows zero-downtime key rotation.
# Must be >=16 chars and not a known placeholder when NODE_ENV=production.
API_KEY=
# Set true ONLY for local development to bypass auth (refused when NODE_ENV=production).
DISABLE_AUTH=false
# SSRF: set true ONLY on trusted internal deployments to allow scraping private IPs.
ALLOW_PRIVATE_NETWORK_SCRAPE=false
# Max JSON/body size. Requests are only URLs+options, so keep this small.
MAX_BODY_SIZE=1mb

# ===== Rate Limiting (per API key, falls back to IP) =====
RATE_LIMIT_DISABLE=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL=120       # all /api traffic per window
RATE_LIMIT_EXPENSIVE=20     # scrape / extract / summarize / map / batch
RATE_LIMIT_CRAWL=10         # crawl kickoff (fans out to many fetches)
RATE_LIMIT_STATUS=600       # status/polling endpoints

# ===== Crawl limits (hard ceilings enforced on /api/crawl) =====
MAX_CRAWL_LIMIT=1000        # max pages per crawl
MAX_CRAWL_DEPTH=10          # max crawl depth
MAX_CRAWL_CONCURRENCY=10    # max concurrent crawlers/browser pool per request
CRAWLER_CONCURRENCY=3       # BullMQ worker concurrency
MAX_SITEMAP_DEPTH=5         # recursive sitemap-index descent cap

# ===== Browser Pool =====
MAX_BROWSERS=3                    # max concurrent Chromium instances
MAX_CONTEXTS_PER_BROWSER=8        # contexts per browser

# ===== Redis =====
# Option A (recommended for managed Redis): full URL, supports rediss:// for TLS + auth
# REDIS_URL=rediss://default:password@host:6379
# Option B: discrete settings (docker-compose). Use service name 'redis', not localhost.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ===== Server =====
PORT=3000
NODE_ENV=development
SERVER_HEADERS_TIMEOUT_MS=120000
SERVER_REQUEST_TIMEOUT_MS=300000
SHUTDOWN_TIMEOUT_MS=30000

# ===== Caching =====
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_DIRECTORY=./cache
CACHE_MAX_AGE_MS=86400000         # sweep cache entries older than this (24h)

# ===== Crawl File Export =====
CRAWL_OUTPUT_DIR=./crawl-output
CRAWL_RETENTION_DAYS=7            # auto-clean exported crawl output older than this

# ===== Logging =====
LOG_LEVEL=info
LOG_TO_FILE=true                 # set false to log only to stdout (managed platforms)
LOG_DIRECTORY=./logs
LOG_MAX_SIZE=20m                 # per-file size before rotation
LOG_MAX_FILES=14d                # retention for rotated logs

# ===== Search (/api/search) =====
# Reliable keyed provider (recommended). Free tier at serper.dev.
SERPER_API_KEY=
# Or a self-hosted SearXNG instance base URL.
SEARXNG_URL=
# (With neither set, /api/search falls back to keyless DuckDuckGo — best-effort;
#  DuckDuckGo anti-bot-challenges datacenter IPs so results may be empty.)

# ===== Observability & quotas =====
# Per-API-key daily request quota (0/unset = unlimited). Per-key overrides:
DAILY_QUOTA=0
# DAILY_QUOTA_OVERRIDES=keyA:5000,keyB:100000

# ===== Process role (horizontal scaling) =====
# web = serve API + enqueue; worker = process jobs only; all = both (default).
ROLE=all

# ===== CORS =====
# Set true to allow ALL origins (development only!)
CORS_OPEN_MODE=false
# Comma-separated allowed origins for production (empty blocks all cross-origin).
ALLOWED_ORIGINS=

# ===== Batch Processing =====
BATCH_PROCESSING_ENABLED=true
BATCH_OUTPUT_DIR=./batch-output
BATCH_CLEANUP_DAYS=7
BATCH_MAX_CONCURRENT_JOBS=5

# ===== Scrape capabilities =====
# Allow the `executeJs` scrape option (raw in-page JS). Set false to disable.
ENABLE_JS_EXECUTION=true
# Change-tracking snapshot TTL in seconds (default 30 days).
CHANGE_TRACKING_TTL=2592000

# ===== Async task queue (extract / llmstxt / async scrape) =====
# Worker concurrency for the BullMQ-backed task queue.
TASK_CONCURRENCY=3

# ===== Document parsing (/api/parse) =====
# Max document size in bytes for PDF/DOCX/HTML parsing (default 25 MB).
MAX_DOC_BYTES=26214400

# ===== Interactive sessions (/api/sessions) =====
# Max concurrent live browser sessions, idle reap, and absolute max lifetime (ms).
MAX_BROWSER_SESSIONS=10
SESSION_IDLE_TTL_MS=300000
SESSION_MAX_LIFETIME_MS=1800000
SESSION_ACTION_TIMEOUT_MS=30000

# ===== Autonomous agent (/api/agent) =====
# Hard cap on navigation steps; observation truncation for the LLM.
AGENT_MAX_STEPS_CAP=20
AGENT_OBS_CHARS=3500
AGENT_MAX_LINKS=40

# ===== Self-healing extraction (/api/extract-auto) =====
# Derived CSS-schema cache TTL (seconds), breakage threshold (0-1), HTML sample cap.
SELF_HEAL_SCHEMA_TTL=604800
SELF_HEAL_HEALTHY_RATIO=0.5
SELF_HEAL_MAX_HTML_CHARS=40000

# ===== Site -> MCP endpoint generator (/api/sites) =====
# Scheduled verifier cadence in ms (re-runs opt-in specs + self-heals on drift).
# 24h default; set <=0 to disable. Derived-schema durability is on the spec itself.
SITE_VERIFY_INTERVAL_MS=86400000

# ===== Hidden-API discovery (/api/discover-apis) =====
# Max endpoints returned; settle time (ms) to catch late XHR/fetch after load.
API_DISCOVERY_MAX=50
API_DISCOVERY_SETTLE_MS=1500

# ===== Anti-bot fingerprint hygiene =====
# Applies consistent fingerprints + patches automation leaks on the browser path.
# NOT CAPTCHA-solving; robots.txt is still respected. Set false for honest/plain UA.
# (browser scrapes use MAX_BROWSERS stealth by default; sessions use SESSION_STEALTH)
SESSION_STEALTH=true

# ===== Proxy rotation (browser path only; NO CAPTCHA/unlocker) =====
# Comma-separated egress proxies, e.g. "http://user:pass@host:8000,http://host2:8000".
# Empty = disabled. Applied to the browser pool, sessions, and agent — NOT the
# HTTP/axios path (which pins per-hop IPs for SSRF protection).
PROXY_LIST=
# PROXY_ENABLED=false        # disable without clearing the list
# PROXY_USERNAME=            # shared creds when not embedded per-proxy
# PROXY_PASSWORD=
PROXY_MAX_FAILURES=3
PROXY_COOLDOWN_MS=60000
